# =============================================================================
# Broadvoice Bugfix Agent — Environment Variables
# =============================================================================
# Copy this file to .sandcastle/.env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# ANTHROPIC (required)
# -----------------------------------------------------------------------------
# Your Anthropic API key. Get it at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude model for the Fix Agent (high-effort task)
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
FIX_AGENT_MODEL=claude-opus-4-6

# Claude model for the Review Agent (lighter task, cheaper)
REVIEW_AGENT_MODEL=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# JIRA (required)
# -----------------------------------------------------------------------------
JIRA_EMAIL=you@yourcompany.com

# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3x...

# No trailing slash
JIRA_BASE_URL=https://yourcompany.atlassian.net

# The project key where bugs live (e.g. CUU, BUG, BV)
JIRA_PROJECT_KEY=BUG

# Custom field ID for "Steps to Reproduce".
# Find it: GET /rest/api/3/field | jq '.[] | select(.name | test("Steps"; "i"))'
JIRA_STEPS_TO_REPRODUCE_FIELD=customfield_10034


# -----------------------------------------------------------------------------
# GIT PROVIDER (required)
# -----------------------------------------------------------------------------
# Which Git hosting provider to use: github | bitbucket
GIT_PROVIDER=github


# -----------------------------------------------------------------------------
# GITHUB (required if GIT_PROVIDER=github)
# -----------------------------------------------------------------------------
# Personal Access Token or fine-grained token.
# Required scopes: Contents (read/write), Pull requests (read/write), Issues (read/write)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# GitHub username or organisation that owns the repo
GITHUB_OWNER=yourorg

# Repository name (without owner prefix)
GITHUB_REPO=your-repo-name

# Base branch that agent PRs will target
GITHUB_BASE_BRANCH=main


# -----------------------------------------------------------------------------
# BITBUCKET (required if GIT_PROVIDER=bitbucket)
# -----------------------------------------------------------------------------
# Workspace slug from bitbucket.org/{workspace}/...
BITBUCKET_WORKSPACE=yourworkspace

BITBUCKET_REPO_SLUG=your-repo-name

# Create at: https://bitbucket.org/account/settings/app-passwords
# Required permissions: Repositories (Read/Write), Pull requests (Read/Write)
BITBUCKET_APP_PASSWORD=ATBBX...

# Your Bitbucket @username (not email)
BITBUCKET_USERNAME=yourbitbucketusername

# Base branch that agent PRs target
BITBUCKET_BASE_BRANCH=develop


# -----------------------------------------------------------------------------
# CODEFRESH (optional)
# -----------------------------------------------------------------------------
CODEFRESH_ENABLED=false
CODEFRESH_API_KEY=...
CODEFRESH_PIPELINE_NAME=broadvoice-pr-build
CODEFRESH_TIMEOUT_SECONDS=300


# -----------------------------------------------------------------------------
# SLACK (optional)
# -----------------------------------------------------------------------------
SLACK_ENABLED=false

# Bot token — scopes needed: chat:write, chat:write.public
SLACK_BOT_TOKEN=xoxb-...

# Channel ID (right-click channel → Copy link → last segment)
SLACK_CHANNEL_ID=C0123456789


# -----------------------------------------------------------------------------
# PIPELINE BEHAVIOUR (optional — defaults shown)
# -----------------------------------------------------------------------------
MAX_FIX_ITERATIONS=3
MAX_REVIEW_ITERATIONS=2
DRY_RUN=false
LOG_LEVEL=info
